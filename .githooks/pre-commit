#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

if command -v bun >/dev/null 2>&1; then
  PACKAGE_RUNNER="bun"
elif command -v npm >/dev/null 2>&1 && command -v npx >/dev/null 2>&1; then
  PACKAGE_RUNNER="npm"
else
  echo "Error: neither bun nor npm/npx is installed."
  exit 1
fi

staged_files=()
staged_files_rel=()
eslint_files=()
eslint_files_rel=()

while IFS= read -r -d '' file; do
  case "$file" in
    client/*)
      staged_files+=("$file")
      staged_files_rel+=("${file#client/}")
      case "$file" in
        *.js|*.jsx|*.mjs|*.cjs|*.ts|*.tsx|*.mts|*.cts)
          eslint_files+=("$file")
          eslint_files_rel+=("${file#client/}")
          ;;
      esac
      ;;
  esac
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if [ "${#staged_files[@]}" -eq 0 ]; then
  echo "No staged files in client/. Skipping pre-commit checks."
  exit 0
fi

if [ "${#eslint_files[@]}" -gt 0 ]; then
  echo "Running ESLint on staged client files..."
  (
    cd "$ROOT_DIR/client"
    if [ "$PACKAGE_RUNNER" = "bun" ]; then
      bunx eslint "${eslint_files_rel[@]}"
    else
      npx --no-install eslint "${eslint_files_rel[@]}"
    fi
  )
fi

echo "Running Prettier check on staged client files..."
(
  cd "$ROOT_DIR/client"
  if [ "$PACKAGE_RUNNER" = "bun" ]; then
    bunx prettier --check --ignore-unknown "${staged_files_rel[@]}"
  else
    npx --no-install prettier --check --ignore-unknown "${staged_files_rel[@]}"
  fi
)

echo "Pre-commit checks passed."


