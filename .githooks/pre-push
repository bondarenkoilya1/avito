#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

if command -v bun >/dev/null 2>&1; then
  PACKAGE_RUNNER="bun"
elif command -v npm >/dev/null 2>&1; then
  PACKAGE_RUNNER="npm"
else
  echo "Error: neither bun nor npm is installed."
  exit 1
fi

if [ ! -f "$ROOT_DIR/client/package.json" ]; then
  echo "Error: client/package.json not found."
  exit 1
fi

echo "Running client checks before push..."
(
  cd "$ROOT_DIR/client"
  if [ "$PACKAGE_RUNNER" = "bun" ]; then
    bun run type-check
    bun run lint
    bun run build
  else
    npm run type-check
    npm run lint
    npm run build
  fi
)

echo "Client checks passed."
